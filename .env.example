# ==============================
# Server
# ==============================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ==============================
# Supabase PostgreSQL
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection String (URI)
# ==============================
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DB_SSL=true

# ==============================
# JWT
# ==============================
JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ==============================
# File Uploads
# ==============================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ==============================
# Default Admin (used by npm run seed)
# ==============================
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_EMAIL=admin@maxmatrix.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_COMPANY_NAME=My Company Pvt Ltd

# ==============================
# Platform Owner / Super Admin (used by npm run seed)
# ==============================
PLATFORM_OWNER_NAME=Platform Owner
PLATFORM_OWNER_EMAIL=owner@maxmatrix.com
PLATFORM_OWNER_PASSWORD=Owner@123
